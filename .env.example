# Admin User (for seed)
ADMIN_EMAIL="your-email@example.com"
ADMIN_PASSWORD="your-secure-password"
ADMIN_NAME="Admin User"

# SDR User (optional - for seed)
SDR_EMAIL="sdr@example.com"
SDR_PASSWORD="sdr-password"
SDR_NAME="SDR User"

# Internal API Authentication (for server-to-server communication)
INTERNAL_API_KEY="your-internal-api-key-generate-with-openssl-rand-base64-32"
WEBHOOK_SECRET="your-webhook-secret-generate-with-openssl-rand-base64-32"



# GoTo Connect Integration
GOTO_CLIENT_ID="your-goto-client-id"
GOTO_CLIENT_SECRET="your-goto-client-secret"
GOTO_ACCOUNT_KEY="your-goto-account-key"
GOTO_WEBHOOK_SECRET="generate-with-openssl-rand-base64-32"
