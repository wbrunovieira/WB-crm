# Database (PostgreSQL)
DATABASE_URL="postgresql://crm_user:dev_password_123@localhost:5499/crm_db"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
